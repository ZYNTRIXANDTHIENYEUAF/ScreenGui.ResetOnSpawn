local Camera = workspace.CurrentCamera
local ESPs = {}
local roleCache = {}
local lastCacheUpdate = 0

local function updateRoleCache()
    local now = os.clock()
    if now - lastCacheUpdate < 0.5 then return end
    lastCacheUpdate = now
    for _, plr in ipairs(game.Players:GetPlayers()) do
        if plr ~= LocalPlayer then
            local bp = plr:FindFirstChild("Backpack")
            local char = plr.Character
            local hasKnife = (bp and bp:FindFirstChild("Knife")) or (char and char:FindFirstChild("Knife"))
            local hasGun = (bp and bp:FindFirstChild("Gun")) or (char and char:FindFirstChild("Gun"))
            if hasKnife then roleCache[plr] = "MURDER"
            elseif hasGun then roleCache[plr] = "SHERIFF"
            else roleCache[plr] = "INNOCENT" end
        end
    end
end

local function getColor(role)
    if role == "MURDER" then return Color3.fromRGB(255, 0, 0)
    elseif role == "SHERIFF" then return Color3.fromRGB(0, 150, 255)
    else return Color3.fromRGB(0, 255, 100) end
end

local function createESP(plr)
    if plr == LocalPlayer or ESPs[plr] then return end
    local line = Drawing.new("Line")
    line.Thickness = 1.5; line.Transparency = 0.7; line.Visible = false
    local text = Drawing.new("Text")
    text.Size = 13; text.Center = true; text.Outline = true; text.Visible = false
    ESPs[plr] = {Line = line, Text = text}
end

local function removeESP(plr)
    if ESPs[plr] then
        pcall(function() ESPs[plr].Line:Remove() end)
        pcall(function() ESPs[plr].Text:Remove() end)
        ESPs[plr] = nil
    end
    roleCache[plr] = nil
end

for _, p in ipairs(game.Players:GetPlayers()) do createESP(p) end
table.insert(_G.ZyntrixGlobalLoops, game.Players.PlayerAdded:Connect(createESP))
table.insert(_G.ZyntrixGlobalLoops, game.Players.PlayerRemoving:Connect(removeESP))

-- HỆ THỐNG VÒNG LẶP KẾT HỢP: NOCLIP VÀ TÀNG HÌNH DÌM TỌA ĐỘ GỐC CỦA NÍ
table.insert(_G.ZyntrixGlobalLoops, game:GetService("RunService").Heartbeat:Connect(function()
    local character = LocalPlayer.Character
    local rootPart = character and character:FindFirstChild("HumanoidRootPart")
    local humanoid = character and character:FindFirstChildOfClass("Humanoid")

    -- 1. Xử lý Noclip xuyên tường liên tục trên vòng lặp Heartbeat
    if noclipActive and character then
        for _, part in pairs(character:GetChildren()) do
            if part:IsA("BasePart") then part.CanCollide = false end
        end
    end

    -- 2. Xử lý logic Tàng hình hạ tọa độ gốc sâu dưới lòng đất (-200000) của ní
    if invisibleActive and rootPart and humanoid and rootPart.Parent and humanoid.Parent then
        local cf = rootPart.CFrame
        local camOffset = humanoid.CameraOffset
        local hidden = cf * CFrame.new(0, -200000, 0)
        
        rootPart.CFrame = hidden
        humanoid.CameraOffset = hidden:ToObjectSpace(CFrame.new(cf.Position)).Position
        
        game:GetService("RunService").RenderStepped:Wait()
        
        if rootPart and humanoid and rootPart.Parent and humanoid.Parent then
            rootPart.CFrame = cf
            humanoid.CameraOffset = camOffset
        end
    end
end))

-- Vòng lặp RenderStepped độc lập tối ưu đồ họa đường truyền Line ESP chống lag
table.insert(_G.ZyntrixGlobalLoops, game:GetService("RunService").RenderStepped:Connect(function()
    if not espActive then
        for _, esp in pairs(ESPs) do esp.Line.Visible = false; esp.Text.Visible = false end
        return
    end
    updateRoleCache()
    local camPos = Camera.CFrame.Position
    local viewX, viewY = Camera.ViewportSize.X / 2, Camera.ViewportSize.Y

    for plr, esp in pairs(ESPs) do
        local char = plr.Character
        local hrp = char and char:FindFirstChild("HumanoidRootPart")
        if hrp and char:FindFirstChildOfClass("Humanoid") and char:FindFirstChildOfClass("Humanoid").Health > 0 then
            local pos, onScreen = Camera:WorldToViewportPoint(hrp.Position)
            if onScreen then
                local role = roleCache[plr] or "INNOCENT"
                local color = getColor(role)
                esp.Line.From = Vector2.new(viewX, viewY)
                esp.Line.To = Vector2.new(pos.X, pos.Y)
                esp.Line.Color = color; esp.Line.Visible = true
                local dist = (camPos - hrp.Position).Magnitude
                esp.Text.Text = plr.Name .. " [" .. math.floor(dist) .. "]"
                esp.Text.Position = Vector2.new(pos.X, pos.Y - 15)
                esp.Text.Color = color; esp.Text.Visible = true
            else esp.Line.Visible = false; esp.Text.Visible = false end
        else esp.Line.Visible = false; esp.Text.Visible = false end
    end
end))

