repeat task.wait() until game.Players.LocalPlayer
local LocalPlayer = game.Players.LocalPlayer
local RunService = game:GetService("RunService")
local UserInputService = game:GetService("UserInputService")
local Camera = workspace.CurrentCamera

local walkSpeed = 16
local noclipActive = false
local infJumpActive = false
local espActive = false

-- HỆ THỐNG LINE ESP CHUẨN
local ESPs = {}
local function createESP(plr)
    if plr == LocalPlayer or ESPs[plr] then return end
    local line = Drawing.new("Line")
    line.Thickness = 1.5
    line.Transparency = 0.7
    line.Color = Color3.fromRGB(255, 85, 85)
    line.Visible = false
    ESPs[plr] = {Line = line}
end
for _, p in ipairs(game.Players:GetPlayers()) do createESP(p) end
game.Players.PlayerAdded:Connect(createESP)
game.Players.PlayerRemoving:Connect(function(plr)
    if ESPs[plr] then
        pcall(function() ESPs[plr].Line:Remove() end)
        ESPs[plr] = nil
    end
end)

