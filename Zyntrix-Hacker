        addBtn("⚔️ Sword Fling", function() loadstring(game:HttpGet("https://rawscripts.net/raw/Universal-Script-FE-Classic-Sword-Fling-Tool-16842"))() end)
    else
        addInput("Speed (Enter)", function(v) walkSpeed = tonumber(v) or 16 end)
        addInput("Jump (Enter)", function(v) jumpPower = tonumber(v) or 50 end)
        addBtn("Noclip: "..(noclip and "ON" or "OFF"), function(b) noclip = not noclip; b.Text = "Noclip: "..(noclip and "ON" or "OFF") end)
