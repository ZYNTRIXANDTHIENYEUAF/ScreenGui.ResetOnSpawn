-- CÁC HÀM TẠO NÚT/INPUT
local function addBtn(txt, func)
    local b = Instance.new("TextButton", ScrollList); b.Size = UDim2.new(0.95, 0, 0, 24); b.Text = txt; b.BackgroundColor3 = Color3.fromRGB(24, 18, 18); b.TextColor3 = Color3.new(1,1,1); Instance.new("UICorner", b).CornerRadius = UDim.new(0, 3); b.MouseButton1Click:Connect(func)
end
local function addInput(p, func)
    local b = Instance.new("TextBox", ScrollList); b.Size = UDim2.new(0.95, 0, 0, 24); b.PlaceholderText = p; b.BackgroundColor3 = Color3.fromRGB(30, 30, 30); b.TextColor3 = Color3.new(1,1,1); b.FocusLost:Connect(function(e) if e then func(b.Text) end end)
end

