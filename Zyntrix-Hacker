        addBtn("Fe Anim Pack", function() loadstring(game:HttpGet("https://rawscripts.net/raw/Universal-Script-Animation-Pack-FE-88221"))() end)
        addBtn("Gaze Emotes", function() loadstring(game:HttpGet("https://rawscripts.net/raw/Universal-Script-Gaze-emotes-V1-54374"))() end)
    end
end

