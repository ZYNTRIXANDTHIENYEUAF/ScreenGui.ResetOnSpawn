-- HÀM FLY TOOL (GIỮ NGUYÊN NHƯ NÍ MUỐN)
local function runFlyToolScript()
    local char = LocalPlayer.Character or LocalPlayer.CharacterAdded:Wait()
    local root = char:WaitForChild("HumanoidRootPart")
    local humanoid = char:WaitForChild("Humanoid")
    local cam = workspace.CurrentCamera
    local tool = Instance.new("Tool"); tool.Name = "Fly Tool"; tool.RequiresHandle = false; tool.Parent = LocalPlayer.Backpack
    local pos, gyro, event
    tool.Equipped:Connect(function()
        pos = Instance.new("BodyPosition", root); pos.MaxForce = Vector3.new(math.huge, math.huge, math.huge); pos.P = 100000; pos.D = 1750
        gyro = Instance.new("BodyGyro", root); gyro.MaxTorque = Vector3.new(math.huge, math.huge, math.huge); gyro.P = 100000; gyro.D = 2200
        event = RunService.Heartbeat:Connect(function()
            local cf = cam.CFrame.Rotation
            local dir = cf:VectorToObjectSpace(humanoid.MoveDirection)
            pos.Position = pos.Position + (cf:VectorToWorldSpace(Vector3.new(dir.X, 0, dir.Z).Unit * dir.Magnitude))
            gyro.CFrame = cam.CFrame; humanoid.PlatformStand = true
        end)
    end)
    tool.Unequipped:Connect(function() if event then event:Disconnect() end; if pos then pos:Destroy() end; if gyro then gyro:Destroy() end; humanoid.PlatformStand = false end)
end

