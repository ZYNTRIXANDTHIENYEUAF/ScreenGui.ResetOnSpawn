local dragging, dragStart, startPos = false, nil, nil
local UIS = game:GetService("UserInputService")

TitleBar.InputBegan:Connect(function(input)
    if input.UserInputType == Enum.UserInputType.MouseButton1 or input.UserInputType == Enum.UserInputType.Touch then
        dragging = true; dragStart = input.Position; startPos = Main.Position
    end
end)

UIS.InputChanged:Connect(function(input)
    if dragging and (input.UserInputType == Enum.UserInputType.MouseMovement or input.UserInputType == Enum.UserInputType.Touch) then
        local delta = input.Position - dragStart
        Main.Position = UDim2.new(startPos.X.Scale, startPos.X.Offset + delta.X, startPos.Y.Scale, startPos.Y.Offset + delta.Y)
    end
end)

UIS.InputEnded:Connect(function(input)
    if input.UserInputType == Enum.UserInputType.MouseButton1 or input.UserInputType == Enum.UserInputType.Touch then dragging = false end
end)

UIS.InputBegan:Connect(function(input, gp)
    if not gp and input.KeyCode == Enum.KeyCode.G then
        if sound then sound:Play() end
        invisibleActive = not invisibleActive
        applyInvisPartsState()
        if Main.Visible and Tab2Btn.BackgroundColor3 == Color3.fromRGB(0, 170, 255) then loadTab2() end
    end
end)

-- VÒNG LẶP HỆ THỐNG LOOPS CHẠY NGẦM
setupInvisParts()

table.insert(_G.ZyntrixGlobalLoops, game:GetService("RunService").Heartbeat:Connect(function()
    local char = LocalPlayer.Character
    local hum = char and char:FindFirstChildOfClass("Humanoid")
    local root = char and char:FindFirstChild("HumanoidRootPart")
    
    if hum and hum.Health > 0 then
        if speedActive then hum.WalkSpeed = speedValue end
        if jumpActive then hum.JumpPower = jumpValue end
        if godModeActive then hum.MaxHealth = math.huge; hum.Health = math.huge end
    end
    
    if noclipActive and char then
        for _, part in pairs(char:GetDescendants()) do
            if part:IsA("BasePart") then part.CanCollide = false end
        end
    end
    
    if invisibleActive and root and hum and root.Parent and hum.Parent then
        local oldCF = root.CFrame
        local oldOffset = hum.CameraOffset
        local hiddenCF = oldCF * CFrame.new(0, -200000, 0)
        root.CFrame = hiddenCF
        hum.CameraOffset = hiddenCF:ToObjectSpace(CFrame.new(oldCF.Position)).Position
        game:GetService("RunService").RenderStepped:Wait()
        if root and hum and root.Parent and hum.Parent then
            root.CFrame = oldCF; hum.CameraOffset = oldOffset
        end
    end
end))

table.insert(_G.ZyntrixGlobalLoops, UIS.JumpRequest:Connect(function()
    if infJumpActive then
        local hum = getHumanoid()
        if hum then hum:ChangeState(Enum.HumanoidStateType.Jumping) end
    end
end))

table.insert(_G.ZyntrixGlobalLoops, LocalPlayer.CharacterAdded:Connect(function()
    invisibleActive = false; task.wait(0.5); setupInvisParts()
end))

loadTab1()
