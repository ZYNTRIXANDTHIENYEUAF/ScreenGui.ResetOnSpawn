local isVisible = true
ToggleGuiBtn.MouseButton1Click:Connect(function()
    sound:Play()
    isVisible = not isVisible
    Main.Visible = isVisible
    ToggleGuiBtn.Text = isVisible and "HIDE" or "SHOW"
    ToggleGuiBtn.BackgroundColor3 = isVisible and Color3.fromRGB(20, 24, 32) or Color3.fromRGB(0, 170, 255)
    ToggleGuiBtn.TextColor3 = isVisible and Color3.fromRGB(0, 170, 255) or Color3.new(1, 1, 1)
