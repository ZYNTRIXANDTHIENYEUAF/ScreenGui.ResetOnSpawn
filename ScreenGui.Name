-- CÁC TRẠNG THÁI HỆ THỐNG LOOPS TRONG GAME
local speedValue = 16
local speedActive = false
local jumpValue = 50
local jumpActive = false
local infJumpActive = false
local noclipActive = false
local godModeActive = false
local invisibleActive = false
local espActive = false
local invisParts = {}

_G.ZyntrixGlobalLoops = {}

local function getHumanoid()
    local char = LocalPlayer.Character
    return char and char:FindFirstChildOfClass("Humanoid")
end

local function setupInvisParts()
    local char = LocalPlayer.Character
    invisParts = {}
    if char then
        for _, obj in pairs(char:GetDescendants()) do
            if obj:IsA("BasePart") and obj.Transparency == 0 then
                table.insert(invisParts, obj)
            end
        end
    end
end

local function applyInvisPartsState()
    for _, part in pairs(invisParts) do
        if part and part.Parent then part.Transparency = invisibleActive and 0.5 or 0 end
    end
end

local function runFlyToolScript()
    local char = LocalPlayer.Character or LocalPlayer.CharacterAdded:Wait()
    local root = char:WaitForChild("HumanoidRootPart")
    local humanoid = char:WaitForChild("Humanoid")
    local run = game:GetService("RunService")
    local cam = workspace.CurrentCamera
    local tool = Instance.new("Tool")
    local pos, gyro, cf, dir, direction, event

    tool.Name = "Fly Tool"
    tool.RequiresHandle = false
    tool.Parent = LocalPlayer.Backpack
    local speed = 1
     
    tool.Equipped:Connect(function()
        pos = Instance.new("BodyPosition")
        gyro = Instance.new("BodyGyro")
        pos.Position = root.Position
        pos.MaxForce = Vector3.new(math.huge, math.huge, math.huge)
        pos.P = 100000; pos.D = 1750; pos.Parent = root
        gyro.MaxTorque = Vector3.new(math.huge, math.huge, math.huge)
        gyro.P = 100000; gyro.D = 2200; gyro.Parent = root
        humanoid.PlatformStand = true
        event = run.Heartbeat:Connect(function()
            cf = cam.CFrame.Rotation
            dir = cf:VectorToObjectSpace(humanoid.MoveDirection * speed)
            if dir.Magnitude == 0 then direction = Vector3.new(0,0,0)
            else direction = cf:VectorToWorldSpace(Vector3.new(dir.X, 0, dir.Z).Unit * dir.Magnitude) end
            pos.Position = pos.Position + direction
            gyro.CFrame = cam.CFrame
            for i, o in ipairs(char:GetChildren()) do
                if o:IsA("BasePart") then o.CanCollide = false end
            end
            humanoid.PlatformStand = true
        end)
    end)
     
    tool.Unequipped:Connect(function()
        if event then event:Disconnect() end
        if pos then pos:Destroy() end
        if gyro then gyro:Destroy() end
        humanoid.PlatformStand = false
    end)
end

local function executeToolScript(url, title)
    if sound then sound:Play() end
    game:GetService("StarterGui"):SetCore("SendNotification", {
        Title = "ZYNTRIX EXECUTE", Text = "Đang chạy: " .. title, Duration = 2
    })
    task.spawn(function()
        local success, result = pcall(function() return game:HttpGet(url) end)
        if success then
            pcall(function() loadstring(result)() end)
        else
            game:GetService("StarterGui"):SetCore("SendNotification", {
                Title = "EXECUTE ERROR", Text = "Không thể tải dữ liệu!", Duration = 2
            })
        end
    end)
end

