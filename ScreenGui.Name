-- CẤU TRÚC TAB 2: PLAYER MODS (CÓ CHỨC NĂNG 11 ZYNTRIX CORE)
local function createInputRow(scrollParent, labelName, defaultVal, onToggle, isActive, currentVal)
    local Row = Instance.new("Frame", scrollParent)
    Row.Size = UDim2.new(0.96, 0, 0, 30)
    Row.BackgroundTransparency = 1
    
    local Box = Instance.new("TextBox", Row)
    Box.Size = UDim2.new(0.28, 0, 1, 0)
    Box.Text = tostring(currentVal)
    Box.BackgroundColor3 = Color3.fromRGB(10, 14, 18); Box.TextColor3 = Color3.new(1, 1, 1)
    Box.Font = Enum.Font.Gotham; Box.TextSize = 11
    Instance.new("UICorner", Box)
    
    local Btn = Instance.new("TextButton", Row)
    Btn.Size = UDim2.new(0.68, 0, 1, 0); Btn.Position = UDim2.new(0.32, 0, 0, 0)
    Btn.Text = labelName .. (isActive and ": ON" or ": OFF")
    Btn.BackgroundColor3 = isActive and Color3.fromRGB(0, 120, 180) or Color3.fromRGB(35, 40, 45)
    Btn.TextColor3 = Color3.new(1, 1, 1); Btn.Font = Enum.Font.GothamSemibold; Btn.TextSize = 11
    Instance.new("UICorner", Btn)
    
    Btn.MouseButton1Click:Connect(function()
        sound:Play()
        local num = tonumber(Box.Text) or defaultVal
        onToggle(Btn, num)
    end)
end

local function createToggleBtn(scrollParent, labelName, isActive, onToggle)
    local Btn = Instance.new("TextButton", scrollParent)
    Btn.Size = UDim2.new(0.96, 0, 0, 28)
    Btn.Text = labelName .. (isActive and ": ON" or ": OFF")
    Btn.BackgroundColor3 = isActive and Color3.fromRGB(0, 120, 180) or Color3.fromRGB(35, 40, 45)
    Btn.TextColor3 = Color3.new(1, 1, 1); Btn.Font = Enum.Font.GothamSemibold; Btn.TextSize = 11
    Instance.new("UICorner", Btn)
    
    Btn.MouseButton1Click:Connect(function() sound:Play() onToggle(Btn) end)
end

-- =======================================================
-- HỆ THỐNG ESP QUÉT TỰ ĐỘNG (AUTO-UPDATE HIGHLIGHT & TRACER LINE)
-- =======================================================
local Camera = workspace.CurrentCamera

-- Hàm xóa ESP của một người chơi cụ thể
local function removeESP(player)
    if player.Character then
        local oldHighlight = player.Character:FindFirstChild("ZyntrixHighlightESP")
        if oldHighlight then oldHighlight:Destroy() end
    end
    if player:GetAttribute("ZyntrixLine") then
        local line = player:GetAttribute("ZyntrixLine")
        pcall(function() line:Remove() end)
        player:SetAttribute("ZyntrixLine", nil)
    end
end

-- Hàm dọn sạch toàn bộ ESP khi tắt nút
local function clearAllESP()
    for _, p in pairs(game.Players:GetPlayers()) do
        removeESP(p)
    end
end

-- Hàm xử lý và cập nhật ESP (Viền + Line khoảng cách) cho từng người chơi
local function applyESP(p)
    if p == LocalPlayer then return end
    
    -- 1. Xử lý phần VIỀN (Highlight)
    if espActive and p.Character and p.Character:FindFirstChild("HumanoidRootPart") then
        local hl = p.Character:FindFirstChild("ZyntrixHighlightESP")
        if not hl then
            hl = Instance.new("Highlight")
            hl.Name = "ZyntrixHighlightESP"
            hl.FillColor = Color3.fromRGB(0, 170, 255)
            hl.FillTransparency = 0.6
            hl.OutlineColor = Color3.new(1, 1, 1)
            hl.OutlineTransparency = 0
            hl.Parent = p.Character
        end
    else
        local hl = p.Character and p.Character:FindFirstChild("ZyntrixHighlightESP")
        if hl then hl:Destroy() end
    end

    -- 2. Xử lý phần LINE KHOẢNG CÁCH (Tracer Line bằng Drawing API)
    if espActive and p.Character and p.Character:FindFirstChild("HumanoidRootPart") and p.Character:FindFirstChildOfClass("Humanoid") and p.Character:FindFirstChildOfClass("Humanoid").Health > 0 then
        local line = p:GetAttribute("ZyntrixLine")
        if not line then
            line = Drawing.new("Line")
            line.Color = Color3.fromRGB(0, 170, 255)
            line.Thickness = 1.5
            line.Transparency = 0.8
            p:SetAttribute("ZyntrixLine", line)
        end
        
        -- Cập nhật tọa độ từ chân màn hình đến vị trí người chơi
        local hrp = p.Character.HumanoidRootPart
        local screenPos, onScreen = Camera:WorldToViewportPoint(hrp.Position)
        
        if onScreen then
            line.From = Vector2.new(Camera.ViewportSize.X / 2, Camera.ViewportSize.Y) -- Gốc từ giữa cạnh dưới màn hình
            line.To = Vector2.new(screenPos.X, screenPos.Y)
            line.Visible = true
        else
            line.Visible = false
        end
    else
        if p:GetAttribute("ZyntrixLine") then
            local line = p:GetAttribute("ZyntrixLine")
            line.Visible = false
        end
    end
end

-- Khởi động vòng lặp tự động cập nhật ESP khi bật
task.spawn(function()
    while true do
        task.wait(0.03) -- Chạy mượt mà khoảng 30 FPS để không gây lag máy
        if espActive then
            for _, p in pairs(game.Players:GetPlayers()) do
                pcall(function() applyESP(p) end)
            end
        end
    end
end)

-- Tự động dọn dẹp bộ nhớ khi có người thoát phòng
game.Players.PlayerRemoving:Connect(function(p)
    removeESP(p)
end)

-- Giao diện quản lý Tab 2
local function loadTab2()
    clearContainer()
    Tab1Btn.BackgroundColor3 = Color3.fromRGB(28, 35, 48)
    Tab1Btn.TextColor3 = Color3.fromRGB(0, 170, 255)
    Tab2Btn.BackgroundColor3 = Color3.fromRGB(0, 170, 255)
    Tab2Btn.TextColor3 = Color3.new(1, 1, 1)

    local PlayerScroll = Instance.new("ScrollingFrame", Container)
    PlayerScroll.Size = UDim2.new(1, 0, 1, 0)
    PlayerScroll.BackgroundTransparency = 1
    PlayerScroll.ScrollBarThickness = 4
    PlayerScroll.ScrollBarImageColor3 = Color3.fromRGB(0, 170, 255)
    PlayerScroll.CanvasSize = UDim2.new(0, 0, 0, 375)

    local ListLayout = Instance.new("UIListLayout", PlayerScroll)
    ListLayout.SortOrder = Enum.SortOrder.LayoutOrder
    ListLayout.Padding = UDim.new(0, 4)

    createInputRow(PlayerScroll, "Speed", 16, function(btn, num)
        speedActive = not speedActive; speedValue = num
        if speedActive then btn.Text = "Speed: ON (" .. speedValue .. ")" btn.BackgroundColor3 = Color3.fromRGB(0, 120, 180)
        else btn.Text = "Speed: OFF" btn.BackgroundColor3 = Color3.fromRGB(35, 40, 45)
            local hum = getHumanoid() if hum then hum.WalkSpeed = 16 end
        end
    end, speedActive, speedValue)

    createInputRow(PlayerScroll, "Jump", 50, function(btn, num)
        jumpActive = not jumpActive; jumpValue = num
        local hum = getHumanoid() if hum then hum.UseJumpPower = true end
        if jumpActive then btn.Text = "Jump: ON (" .. jumpValue .. ")" btn.BackgroundColor3 = Color3.fromRGB(0, 120, 180)
        else btn.Text = "Jump: OFF" btn.BackgroundColor3 = Color3.fromRGB(35, 40, 45)
            if hum then hum.JumpPower = 50 end
        end
    end, jumpActive, jumpValue)

    createToggleBtn(PlayerScroll, "Inf Jump", infJumpActive, function(btn)
        infJumpActive = not infJumpActive
        btn.Text = infJumpActive and "Inf Jump: ON" or "Inf Jump: OFF"
        btn.BackgroundColor3 = infJumpActive and Color3.fromRGB(0, 120, 180) or Color3.fromRGB(35, 40, 45)
    end)

    createToggleBtn(PlayerScroll, "Noclip", noclipActive, function(btn)
        noclipActive = not noclipActive
        btn.Text = noclipActive and "Noclip: ON" or "Noclip: OFF"
        btn.BackgroundColor3 = noclipActive and Color3.fromRGB(0, 120, 180) or Color3.fromRGB(35, 40, 45)
    end)

    createToggleBtn(PlayerScroll, "God Mode", godModeActive, function(btn)
        godModeActive = not godModeActive
        btn.Text = godModeActive and "God Mode: ON" or "God Mode: OFF"
        btn.BackgroundColor3 = godModeActive and Color3.fromRGB(0, 120, 180) or Color3.fromRGB(35, 40, 45)
    end)

    createToggleBtn(PlayerScroll, "Invisible (Key G)", invisibleActive, function(btn)
        invisibleActive = not invisibleActive
        btn.Text = invisibleActive and "Invisible: ON" or "Invisible: OFF"
        btn.BackgroundColor3 = invisibleActive and Color3.fromRGB(0, 120, 180) or Color3.fromRGB(35, 40, 45)
        applyInvisPartsState()
    end)

    createToggleBtn(PlayerScroll, "Hitbox Expander", false, function(btn)
        executeToolScript("https://raw.githubusercontent.com/Mimichan-script-bypass/Test-script/main/Hitbox", "Hitbox Expander")
        btn.Text = "Hitbox: LOADED"; btn.BackgroundColor3 = Color3.fromRGB(0, 120, 180)
    end)

    -- Nút bật tắt hệ thống ESP tự động cập nhật mới
    createToggleBtn(PlayerScroll, "ESP Viền + Line", espActive, function(btn)
        espActive = not espActive
        btn.Text = espActive and "ESP: ON" or "ESP: OFF"
        btn.BackgroundColor3 = espActive and Color3.fromRGB(0, 120, 180) or Color3.fromRGB(35, 40, 45)
        if not espActive then clearAllESP() end
    end)

    createToggleBtn(PlayerScroll, "🎭 Animation Pack FE", false, function(btn)
        executeToolScript("https://rawscripts.net/raw/Universal-Script-Animation-Pack-FE-88221", "Animation Pack")
        btn.Text = "Animations: LOADED"; btn.BackgroundColor3 = Color3.fromRGB(0, 120, 180)
    end)

    createToggleBtn(PlayerScroll, "🕺 Gaze Emotes V1", false, function(btn)
        executeToolScript("https://rawscripts.net/raw/Universal-Script-Gaze-emotes-V1-54374", "Gaze Emotes")
        btn.Text = "Gaze Emotes: LOADED"; btn.BackgroundColor3 = Color3.fromRGB(0, 120, 180)
    end)

    createToggleBtn(PlayerScroll, "⚡ EXECUTE ZYNTRIX CORE", false, function(btn)
        btn.Text = "EXECUTING CORE..."
        btn.BackgroundColor3 = Color3.fromRGB(40, 40, 50)
        task.spawn(function()
            local success, _ = pcall(function() 
                loadstring(game:HttpGet("https://raw.githubusercontent.com/ZYNTRIXANDTHIENYEUAF/game.CoreGui/main/Zyntrix"))() 
            end)
            if success then
                btn.Text = "ZYNTRIX CORE: LOADED"
                btn.BackgroundColor3 = Color3.fromRGB(0, 170, 120)
            else
                btn.Text = "CORE LOAD FAILED!"
                btn.BackgroundColor3 = Color3.fromRGB(180, 50, 50)
                task.wait(1.5)
                btn.Text = "⚡ EXECUTE ZYNTRIX CORE"
                btn.BackgroundColor3 = Color3.fromRGB(35, 40, 45)
            end
        end)
    end)
end

